# OpenAI (or any OpenAI-compatible provider e.g. Groq)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=                      # optional: e.g. https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile  # optional: defaults to llama-3.3-70b-versatile

# JIRA Cloud
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=you@yourorg.com
JIRA_API_TOKEN=your-jira-api-token

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-github-org-name   # optional: used by npm run sync-team

# Server
PORT=3000
LOG_LEVEL=info

# Integration test targets (only needed for npm run test:integration)
TEST_JIRA_ACCOUNT_ID=
TEST_GITHUB_USERNAME=
