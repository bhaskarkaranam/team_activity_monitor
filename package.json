{
  "name": "team-activity-monitor",
  "version": "1.0.0",
  "description": "AI chatbot for team activity monitoring via JIRA and GitHub",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "sync-team": "node src/scripts/sync-team.js",
    "test": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit --runInBand"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "openai": "^4.20.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nock": "^13.4.0",
    "nodemon": "^3.0.0"
  },
  "nodemonConfig": {
    "ignore": [
      "config/team.json"
    ]
  }
}
